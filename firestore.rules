rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields:
    //   - name: string (required)
    //   - price: number (required)
    //   - image: string (required)
    //   - description: string (optional)
    //   - category: string (optional)
    //   - stock: number (optional)
    //   - createdAt: string (ISO 8601)
    //
    // Collection: orders
    // Fields:
    //   - customerName: string (required)
    //   - customerEmail: string (optional)
    //   - customerAddress: string (required)
    //   - customerPhone: string (optional)
    //   - items: list (required)
    //   - totalAmount: number (required)
    //   - status: string (required, enum: pending, processing, shipped, delivered, cancelled)
    //   - paymentMethod: string (required, enum: COD)
    //   - createdAt: string (ISO 8601)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "mimpy124ahon124@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.matches("^https?://.*") &&
             (!('stock' in data) || (data.stock is number && data.stock >= 0)) &&
             (!('category' in data) || (data.category is string && data.category.size() < 100));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'customerAddress', 'items', 'totalAmount', 'status']) &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.customerAddress is string && data.customerAddress.size() > 0 && data.customerAddress.size() < 500 &&
             data.items is list && data.items.size() > 0 && data.items.size() < 50 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             (!('paymentMethod' in data) || data.paymentMethod == 'COD');
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(request.resource.data);
      allow read, update, delete: if isAdmin();
    }
  }
}
